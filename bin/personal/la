#!/usr/bin/env bash

# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

# Use the "ls" function, which shadows the ls command with certain flags
# applied.
source "$D_BASH_FUNCTIONS"/ls.bash

ls --all "$@"
