#!/usr/bin/env bash

##
# This simply aliases "toilet" as "block" for situations, including work
# situations, where "toilet" would be an odd term for me to type on screen.

# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

toilet "$@"
