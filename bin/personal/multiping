#!/usr/bin/env bash

# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

multitail -s 2 \
  -p l -l 'ping 1.1.1.1' \
  -p l -l 'ping google.com' \
  -p l -l 'ping 8.8.8.8' \
  -p l -l 'ping example.com' \
