# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
  multitail
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  fold >&2 --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    echo >&2 "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Ping two IP addresses and two domains simultaneously, showing all results.

Results are shown in a 2x2 grid of rectangles.

This can be helpful when you want to test your internet connection and/or when
you want to know when your internet connection is re-established.

Because two IP addresses and two domains are pinged, this should also reveal if
there is a problem with your DNS records or DNS server, as opposed to your
internet connection. In that case, the pings to IP addresses would succeed but
the pings to the domains would fail.

Press "q" or "CTRL-C" to exit.

Usage:
  $COMMAND_NAME
  $COMMAND_NAME -h | --help

Options:
  -h, --help
      Show this documentation
EOF
)"

multitail -s 2 \
  -l 'ping 1.1.1.1' \
  -l 'ping google.com' \
  -l 'ping 8.8.8.8' \
  -l 'ping example.com'
