# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
  vcsh
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  >&2 fold --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    >&2 echo "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Print files in vcsh repos, relative to the current directory, without headers.

This works like "vcsh foreach ls-files", with some important differences. First,
all files from all vcsh repos are printed, not just those in the current
directory, and all file paths are shown relative to the current directory.
Second, filenames are shown sorted. Finally, headers are not printed for each
repo like "vcsh foreach ls-files" does at the time of this writing. At the time
of this writing, "vcsh foreach ls-files" prints something like the following,
assuming there are two vcsh repos configured, one named "alices-shared-dotfiles"
and one named "alices-private-dotfiles":

  alices-shared-dotfiles:
  shared-dotfile-1
  shared-dotfile-2
  shared-dotfile-3
  alices-private-dotfiles:
  private-dotfile-1
  private-dotfile-2
  private-dotfile-3

By contrast, running "$COMMAND_NAME" would print the following:

  ../parent-private-dotfile-1
  ../parent-private-dotfile-2
  ../parent-private-dotfile-3
  ../parent-shared-dotfile-1
  ../parent-shared-dotfile-2
  ../parent-shared-dotfile-3
  private-dotfile-1
  private-dotfile-2
  private-dotfile-3
  shared-dotfile-1
  shared-dotfile-2
  shared-dotfile-3

Usage:
  $COMMAND_NAME
  $COMMAND_NAME -h | --help

Options:
  -h, --help
      Show this documentation
EOF
)"

for REPO in $(vcsh list); do
  vcsh "$REPO" ls-files "$HOME"
done | sort --unique
