# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  >&2 fold --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    >&2 echo "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Print the path of the current project's root, or exit with an error.

A project root is any directory that contains a subdirectory named ".git",
".hg", or ".svn". If no parent directory contains any of those subdirectories,
an error message is printed and this command exits with exit code 1.

Usage:
  $COMMAND_NAME
  $COMMAND_NAME -h | --help

Options:
  -h, --help
      Show this documentation
EOF
)"

PROJECT_ROOT_DIRECTORIES=(
  ".git"
  ".hg"
  ".svn"
)

found_project_root=false

for DIRECTORY in "${PROJECT_ROOT_DIRECTORIES[@]}"; do
  if [[ -d $DIRECTORY ]]; then
    found_project_root=true
    project_root=$PWD
    break
  fi
done

if [[ $found_project_root == true ]]; then
  echo "$project_root"
else
  if [[ $PWD == / ]]; then
    >&2 cat <<'EOF'
FATAL ERROR: Current directory is not a subdirectory of project.
EOF
    exit 1
  else
    cd ..
    $COMMAND_NAME
  fi
fi
