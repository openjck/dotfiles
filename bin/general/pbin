# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  >&2 fold --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    >&2 echo "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Print, to stdout, the first executable on the \$PATH with the given name.

For example, if you have a script named "indent" in the ~/bin directory, and
the ~/bin directory is on the \$PATH, it could be printed to standard out by
running the following:

  $COMMAND_NAME indent

That command would be equivalent to the following:

  cat \$(which indent)

To instead use "batcat" to print the contents of "indent", run the following:

  $COMMAND_NAME --print-command batcat indent

Usage:
  $COMMAND_NAME [-p PRINT_COMMAND] BIN
  $COMMAND_NAME -h | --help

Options:
  -p PRINT_COMMAND, --print-command PRINT_COMMAND
      The command to use to show the contents of BIN [default: cat]
  -h, --help
      Show this documentation
EOF
)"

FILE=$(which "${ARGS[BIN]}")
${ARGS[--print-command]} "$FILE"
