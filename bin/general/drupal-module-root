# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  fold >&2 --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    echo >&2 "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Print the path of the current Drupal module's root, or exit with an error.

A Drupal module root is any directory that contains a file named
"[directory].info.yml", where "[directory]" is the name of the directory itself.
If no parent directory contains a file with that name, an error message is
printed and this command exits with exit code 1.

Usage:
  $COMMAND_NAME
  $COMMAND_NAME -h | --help

Options:
  -h, --help
      Show this documentation
EOF
)"

function find_drupal_module_root() {
  # https://stackoverflow.com/a/1371283/715866
  DIRECTORY_NAME=${PWD##*/}

  if [[ -f "$DIRECTORY_NAME.info.yml" ]]; then
    echo "$PWD"
  elif [[ $PWD == / ]]; then
    cat >&2 <<'EOF'
FATAL ERROR: Current directory is not a subdirectory of a Drupal module.
EOF
    exit 1
  else
    (cd .. && find_drupal_module_root)
  fi
}

find_drupal_module_root
