# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  >&2 fold --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    >&2 echo "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Run sl (Steam Locomotive) with display-related options applied randomly.

SLR stands for Steam Locomotive Random.

The locomotive displayed by sl will randomly have an accident, be of a smaller
size, and/or fly, to maximize typo amusement.

Unfortunately, docopts, the argument-parsing library that is used by this
command, exits with an error message if unknown options are provided. There is
no apparent way to change that behavior, other than manually supporting every
option and ignoring them. That could be done, but it's not done at this time.
For that reason, this command will exit with an error message if any _other_
option intended for "ls" is provided. To work around that, you can create
a function in your "~/.bashrc" file which drops the extra arguments, like this:

  # Note that the name is slr, with the r, so that it has the same name as this
  # executable.
  function slr() {
    slr -e
  }

  or

  # Note that the name is sl, without the r, so that it maximizes amusement when
  # "ls" typos occur.
  function sl() {
    slr -e
  }

Notice that the arguments to the functions ("\$@") are not passed through to the
slr executable.

Usage:
  $COMMAND_NAME [-e]
  $COMMAND_NAME -h | --help

Options:
  -e
      Allow interrupt by Ctrl+C. (This argument is passed through to sl as-is.)
  -h, --help
      Show this documentation
EOF
)"

# All display-related options that are accepted by Debian's version of sl.
SL_DISPLAY_OPTIONS=(
  '-a'
  '-l'
  '-F'
)

for SL_DISPLAY_OPTION in "${SL_DISPLAY_OPTIONS[@]}"; do
  # Flip a coin...
  if [[ $((RANDOM % 2)) -eq 0 ]]; then
    ARGUMENTS+=("$SL_DISPLAY_OPTION")
  fi
done

if ${ARGS[-e]}; then
  ARGUMENTS+=("-e")
fi

sl "${ARGUMENTS[@]}"
