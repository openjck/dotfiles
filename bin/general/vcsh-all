# Use Bash's unofficial "strict mode."
#
# http://redsymbol.net/articles/unofficial-bash-strict-mode/
set -o errexit
set -o nounset
set -o pipefail
IFS=$'\n\t'

COMMAND_NAME=$(basename "$0")

##########################
# BEGIN DEPENDENCY CHECK #
##########################

DEPENDENCIES=(
  docopts
  vcsh
)

MISSING_DEPENDENCIES=()

for DEPENDENCY in "${DEPENDENCIES[@]}"; do
  if ! command -v "$DEPENDENCY" >/dev/null; then
    MISSING_DEPENDENCIES+=("$DEPENDENCY")
  fi
done

if ((${#MISSING_DEPENDENCIES[@]} > 0)); then
  >&2 fold --spaces <<EOF
FATAL ERROR: The following are not installed. You must install them on your \
own for "$COMMAND_NAME" to function properly.

EOF
  for DEPENDENCY in "${MISSING_DEPENDENCIES[@]}"; do
    >&2 echo "  - $DEPENDENCY"
  done
  exit 1
fi

########################
# END DEPENDENCY CHECK #
########################

eval "$(
  docopts --help=- -A ARGS : "$@" <<EOF
Run a vcsh subcommand in all repos without showing a header for each repo.

This works like "vcsh foreach" (e.g., "vcsh foreach ls-files"), except that it
doesn't print a header for each repo like "vcsh foreach" does at the time of
this writing. At the time of this writing, "vcsh foreach ls-files" prints
something like the following, assuming there are two vcsh repos configured, one
named "alices-shared-dotfiles" and one named "alices-private-dotfiles":

  alices-shared-dotfiles:
  shared-dotfile-1
  shared-dotfile-2
  shared-dotfile-3
  alices-private-dotfiles:
  private-dotfile-1
  private-dotfile-2
  private-dotfile-3

By contrast, running "$COMMAND_NAME ls-files" would print the following:

  shared-dotfile-1
  shared-dotfile-2
  shared-dotfile-3
  private-dotfile-1
  private-dotfile-2
  private-dotfile-3

Usage:
  $COMMAND_NAME COMMAND
  $COMMAND_NAME -h | --help

Options:
  -h, --help
      Show this documentation
EOF
)"

for REPO in $(vcsh list); do
  # We _want_ word splitting here, because the command and its options
  # **cannot** be passed to vcsh as a single argument. For example, this does
  # not work:
  #
  #   vcsh dotfiles-openjck "ls-files --deleted"
  #
  # but this does:
  #
  #   vcsh dotfiles-openjck ls-files --deleted
  #
  # shellcheck disable=SC2086
  vcsh "$REPO" ${ARGS[COMMAND]}
done
